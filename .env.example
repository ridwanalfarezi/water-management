# Optional: Set your Google Gemini API key to enable AI-powered insights
# Get a free key at: https://aistudio.google.com/apikey
# Without this, the system uses rule-based analysis (still useful)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Override the model (default: gemini-2.5-flash-lite)
# Free tier models: gemini-2.5-flash-lite (15 RPM), gemini-2.5-flash (10 RPM)
# GEMINI_MODEL=gemini-2.5-flash-lite
